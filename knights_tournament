import random
import math
from collections import defaultdict
import csv

# --- Tournament and Competitive Knights Implementation ---

BOARD_SIZE = 8
GAMES_PER_PAIR = 100

STRATEGIES = [
    'random', 'min_degree', 'max_degree', 'center', 'edge', 'lex', 'freq', 'weighted', 'aggressive_block'
]

# --- Build Knight Graph ---

def build_knight_adjacency(n=8):
    deltas = [(2,1),(1,2),(-1,2),(-2,1),(-2,-1),(-1,-2),(1,-2),(2,-1)]
    adj = {}
    for r in range(n):
        for c in range(n):
            nbrs = {
                (r+dr, c+dc)
                for dr, dc in deltas
                if 0 <= r+dr < n and 0 <= c+dc < n
            }
            adj[(r, c)] = nbrs
    return adj

# --- Warnsdorff Candidate Generator ---

def get_warnsdorff_moves(pos, visited, adj):
    candidates = []
    for nbr in adj[pos]:
        if nbr in visited:
            continue
        deg = sum(1 for nn in adj[nbr] if nn not in visited)
        candidates.append((deg, nbr))
    if not candidates:
        return []
    min_deg = min(deg for deg, _ in candidates)
    return [nbr for deg, nbr in candidates if deg == min_deg]

# --- Tie‐Breaker State and Helpers ---

freq_counter = defaultdict(int)

def build_weight_map(adj):
    weight = {}
    center = ( (7)/2, (7)/2 )
    for sq in adj:
        d = math.hypot(sq[0] - center[0], sq[1] - center[1])
        weight[sq] = 1.0 / (d + 1.0)
    return weight

WEIGHT_MAP = None

def tiebreak_random(cands, visited, adj, opp_pos=None):
    return random.choice(cands)

def tiebreak_min_degree(cands, visited, adj, opp_pos=None):
    deg2 = {}
    for s in cands:
        vis2 = visited | {s}
        nbrs = [n for n in adj[s] if n not in vis2]
        if not nbrs:
            deg2[s] = 0
        else:
            deg2[s] = min(
                sum(1 for nn in adj[n] if nn not in vis2)
                for n in nbrs
            )
    best = [s for s, d in deg2.items() if d == min(deg2.values())]
    return random.choice(best)

def tiebreak_max_degree(cands, visited, adj, opp_pos=None):
    deg2 = {}
    for s in cands:
        vis2 = visited | {s}
        nbrs = [n for n in adj[s] if n not in vis2]
        if not nbrs:
            deg2[s] = 0
        else:
            deg2[s] = max(
                sum(1 for nn in adj[n] if nn not in vis2)
                for n in nbrs
            )
    best = [s for s, d in deg2.items() if d == max(deg2.values())]
    return random.choice(best)

def tiebreak_center(cands, visited, adj, opp_pos=None):
    dmap = {
        s: max(abs(s[0] - 3.5), abs(s[1] - 3.5))
        for s in cands
    }
    best = [s for s, d in dmap.items() if d == min(dmap.values())]
    return random.choice(best)

def tiebreak_edge(cands, visited, adj, opp_pos=None):
    dmap = {
        s: max(abs(s[0] - 3.5), abs(s[1] - 3.5))
        for s in cands
    }
    best = [s for s, d in dmap.items() if d == max(dmap.values())]
    return random.choice(best)

def tiebreak_lex(cands, visited, adj, opp_pos=None):
    return sorted(cands)[0]

def tiebreak_freq(cands, visited, adj, opp_pos=None):
    freqs = {s: freq_counter[s] for s in cands}
    best = [s for s, f in freqs.items() if f == min(freqs.values())]
    choice = random.choice(best)
    freq_counter[choice] += 1
    return choice

def tiebreak_weighted(cands, visited, adj, opp_pos=None):
    global WEIGHT_MAP
    if WEIGHT_MAP is None:
        WEIGHT_MAP = build_weight_map(adj)
    weights = [WEIGHT_MAP[s] for s in cands]
    return random.choices(cands, weights=weights, k=1)[0]

def tiebreak_aggressive_block(cands, visited, adj, opp_pos):
    block_scores = []
    for s in cands:
        vis_new = visited | {s}
        opp_moves = [n for n in adj[opp_pos] if n not in vis_new]
        block_scores.append((len(opp_moves), s))
    minblock = min(score for score, _ in block_scores)
    best = [s for score, s in block_scores if score == minblock]
    return random.choice(best)

TIE_FUNCS = {
    'random': tiebreak_random,
    'min_degree': tiebreak_min_degree,
    'max_degree': tiebreak_max_degree,
    'center': tiebreak_center,
    'edge': tiebreak_edge,
    'lex': tiebreak_lex,
    'freq': tiebreak_freq,
    'weighted': tiebreak_weighted,
    'aggressive_block': tiebreak_aggressive_block
}

def select_warnsdorff(pos, visited, adj, strategy, opp_pos=None):
    cands = get_warnsdorff_moves(pos, visited, adj)
    if not cands:
        return None
    if len(cands) == 1:
        return cands[0]
    if strategy == 'aggressive_block':
        return TIE_FUNCS[strategy](cands, visited, adj, opp_pos)
    else:
        return TIE_FUNCS[strategy](cands, visited, adj)

def choose_3ply(pos, opp_pos, visited, adj, strategy, other_strategy):
    S1 = get_warnsdorff_moves(pos, visited, adj)
    if not S1:
        return None

    if strategy == 'aggressive_block':
        return tiebreak_aggressive_block(S1, visited, adj, opp_pos)

    best_score = -1
    best_moves = []

    for s1 in S1:
        vis1 = visited | {s1}

        s2 = select_warnsdorff(opp_pos, vis1, adj, other_strategy, pos)
        vis2 = vis1 | {s2} if s2 else vis1

        s3 = select_warnsdorff(s1, vis2, adj, strategy, opp_pos)
        deg3 = sum(1 for n in adj[s3] if n not in vis2) if s3 else 0

        if deg3 > best_score:
            best_score = deg3
            best_moves = [s1]
        elif deg3 == best_score:
            best_moves.append(s1)

    if len(best_moves) == 1:
        return best_moves[0]
    return TIE_FUNCS[strategy](best_moves, visited, adj)

def simulate_two_knights(adj, start1, start2, strat1, strat2):
    visited = {start1, start2}
    seq1, seq2 = [start1], [start2]
    turn, stuck1, stuck2 = 1, False, False

    while True:
        if turn == 1:
            mv = choose_3ply(seq1[-1], seq2[-1], visited, adj, strat1, strat2)
            if mv:
                seq1.append(mv)
                visited.add(mv)
                stuck1 = False
            else:
                stuck1 = True
            turn = 2
        else:
            mv = choose_3ply(seq2[-1], seq1[-1], visited, adj, strat2, strat1)
            if mv:
                seq2.append(mv)
                visited.add(mv)
                stuck2 = False
            else:
                stuck2 = True
            turn = 1

        if stuck1 and stuck2:
            break

    return seq1, seq2

FILES = 'abcdefgh'
def to_algebraic(pos):
    return f"{FILES[pos[1]]}{8-pos[0]}"

def print_move_table(seq1, seq2):
    max_len = max(len(seq1), len(seq2))
    print(f"{'Move':<6}{'K1':<6}{'K2':<6}")
    print("-"*18)
    for i in range(max_len):
        m1 = to_algebraic(seq1[i]) if i < len(seq1) else ""
        m2 = to_algebraic(seq2[i]) if i < len(seq2) else ""
        print(f"{i:02d}    {m1:<6}{m2:<6}")

def print_game_summary(seq1, seq2, strat1, strat2, start1, start2):
    print(f"Knight1 strategy: {strat1:<15} Starting square: {to_algebraic(start1)}")
    print(f"Knight2 strategy: {strat2:<15} Starting square: {to_algebraic(start2)}")
    print(f"Total moves — K1: {len(seq1)-1}, K2: {len(seq2)-1}")
    winner = "Tie"
    if len(seq1) > len(seq2):
        winner = "Knight1"
    elif len(seq2) > len(seq1):
        winner = "Knight2"
    print(f"Winner: {winner}")
    print_move_table(seq1, seq2)

def run_tournament(strategies, games_per_pair=100, board_size=8):
    adj = build_knight_adjacency(board_size)
    squares = list(adj.keys())
    results = {}

    for strat1 in strategies:
        for strat2 in strategies:
            wins1, wins2, ties = 0, 0, 0
            total_moves1, total_moves2 = 0, 0
            for _ in range(games_per_pair):
                start1 = random.choice(squares)
                start2 = random.choice([s for s in squares if s != start1])
                seq1, seq2 = simulate_two_knights(adj, start1, start2, strat1, strat2)
                moves1 = len(seq1) - 1
                moves2 = len(seq2) - 1
                total_moves1 += moves1
                total_moves2 += moves2
                if moves1 > moves2:
                    wins1 += 1
                elif moves2 > moves1:
                    wins2 += 1
                else:
                    ties += 1
            results[(strat1, strat2)] = {
                'win_rate1': wins1 / games_per_pair,
                'win_rate2': wins2 / games_per_pair,
                'tie_rate': ties / games_per_pair,
                'avg_moves1': total_moves1 / games_per_pair,
                'avg_moves2': total_moves2 / games_per_pair
            }
    return results

def print_tournament_results(results, strategies):
    header = f"| Knight1         | Knight2         | Win%K1 | Win%K2 | Tie%  | AvgMovesK1 | AvgMovesK2 |"
    print(header)
    print("|-----------------|-----------------|-------|-------|-------|------------|------------|")
    for strat1 in strategies:
        for strat2 in strategies:
            stats = results[(strat1, strat2)]
            print(f"| {strat1:<15} | {strat2:<15} | {stats['win_rate1']*100:6.1f} | {stats['win_rate2']*100:6.1f} | {stats['tie_rate']*100:6.1f} | {stats['avg_moves1']:.2f}     | {stats['avg_moves2']:.2f}     |")

def export_tournament_results_csv(results, strategies, filename='knight_tournament_results.csv'):
    with open(filename, mode='w', newline='') as csvfile:
        fieldnames = ['Knight1_Strategy', 'Knight2_Strategy', 'WinRate_K1', 'WinRate_K2', 'TieRate', 'AvgMoves_K1', 'AvgMoves_K2']
        writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
        writer.writeheader()
        for strat1 in strategies:
            for strat2 in strategies:
                stats = results[(strat1, strat2)]
                writer.writerow({
                    'Knight1_Strategy': strat1,
                    'Knight2_Strategy': strat2,
                    'WinRate_K1': f"{stats['win_rate1']:.4f}",
                    'WinRate_K2': f"{stats['win_rate2']:.4f}",
                    'TieRate': f"{stats['tie_rate']:.4f}",
                    'AvgMoves_K1': f"{stats['avg_moves1']:.2f}",
                    'AvgMoves_K2': f"{stats['avg_moves2']:.2f}"
                })

if __name__ == "__main__":
    random.seed()
    print("Running tournament...")
    results = run_tournament(STRATEGIES, GAMES_PER_PAIR, BOARD_SIZE)
    print_tournament_results(results, STRATEGIES)
    export_tournament_results_csv(results, STRATEGIES)
    print("\nTournament results have been exported to knight_tournament_results.csv")
    # Example: run one game and show moves
    print("\nExample game with min_degree vs aggressive_block:\n")
    adj = build_knight_adjacency(BOARD_SIZE)
    squares = list(adj.keys())
    start1 = random.choice(squares)
    start2 = random.choice([s for s in squares if s != start1])
